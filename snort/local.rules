##################################################
#TCP Hijacking
##################################################

# === 3) Suspicious User-Agent with Cookie header ===
# Nếu thấy Cookie header nhưng trình duyệt là curl, python-requests, Wget, v.v.
alert http any any -> $HOME_NET any (
  msg:"SNORT SUSPICIOUS Cookie reuse by non-browser client (possible TCP hijack)";
  http_header;
  content:"Cookie:";  # không dùng nocase nữa, regex bên dưới đã có /i
  pcre:"/User-Agent:\s*(?:curl|python|requests|wget|libwww-perl|java|Go-http-client)/i";
  sid:3200003; rev:2; classtype:bad-unknown;
  metadata:service http,policy security-incident;
)
# 3990001 - Minimal test: detect cleartext Cookie PHPSESSID to port 80 (outbound)
alert tcp $HOME_NET any -> $EXTERNAL_NET 80 (
  msg:"TEST Cookie PHPSESSID on HTTP (minimal)";
  content:"Cookie: PHPSESSID=";
  sid:3990001; rev:1; classtype:attempted-user;
)
# 3500001 - Minimal test: detect Cookie header with JSESSIONID or PHPSESSID on outbound HTTP
alert tcp $HOME_NET any -> $EXTERNAL_NET 80 (
  msg:"TEST Cookie header containing session id (JSESSIONID|PHPSESSID)";
  content:"Cookie:";
  pcre:"/(?:JSESSIONID|PHPSESSID|sessionid|sid|auth|token)=/i";
  sid:3500001; rev:1; classtype:attempted-user;
  metadata:service http,policy security-incident;
)

# 3500002 - Detect session cookie used to access index.jsp (EditThisCookie case)
alert http $HOME_NET any -> $EXTERNAL_NET any (
  msg:"LOCAL HTTP Session Cookie used to access /index.jsp (possible EditThisCookie replay)";
  http_header;
  pcre:"/Cookie:\s*(?:.*(?:JSESSIONID|PHPSESSID|sessionid|sid|auth|token)=)/i";
  http_uri;
  content:"/index.jsp";
  sid:3500002; rev:1; classtype:policy-violation;
  metadata:service http,policy security-incident;
)

# 3500003 - Stronger: Browser-like UA + session cookie to /index.jsp (reduce FP)
alert http $HOME_NET any -> $EXTERNAL_NET any (
  msg:"LOCAL Browser UA + Session Cookie to /index.jsp (suspicious EditThisCookie reuse)";
  http_header;
  pcre:"/Cookie:\s*(?:.*(?:JSESSIONID|PHPSESSID|sessionid|sid|auth|token)=)/i";
  pcre:"/User-Agent:\s*(?:Mozilla|Chrome|Firefox|Safari|Edg|OPR)/i";
  http_uri;
  content:"/index.jsp";
  sid:3500003; rev:1; classtype:policy-violation;
  metadata:service http,policy security-incident;
)

