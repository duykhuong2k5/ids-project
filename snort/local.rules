#SQL INJECTION

# 1) sqlmap User-Agent (match header text anywhere in payload)
#alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"SQLI-TOOL sqlmap User-Agent detected"; flow:to_server,established; content:"User-Agent: sqlmap", nocase; sid:1002001; rev:1;)
# 2) fallback: "sqlmap" anywhere
#alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"SQLI-TOOL sqlmap token detected"; flow:to_server,established; content:"sqlmap", nocase; sid:1002006; rev:1;)

# 3) UNION SELECT pattern in payload
#alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"SQLI - possible UNION SELECT"; flow:to_server,established; content:"union select", nocase; detection_filter:track by_src, count 2, seconds 10; sid:1002002; rev:1;)

