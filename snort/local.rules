# local.rules - phishing/SET detection (Snort3 compatible)

# 1009401 - HTTP request có Host header là địa chỉ IP (phishing page host bằng IP)
alert http $HOME_NET any -> any $HTTP_PORTS (
    msg:"PHISH DETECT Social-Engineer Toolkit - HTTP request Host is numeric IP (possible phishing / SET site)";
    flow:to_server,established;
    http_header;
    pcre:"/Host:\s*\d{1,3}(?:\.\d{1,3}){3}(?::\d+)?/i";
    sid:1009401; rev:1; classtype:attempted-admin;
)
# 1009301 - POST có (login|username) + (password|pass) trong body, đích là IP nội bộ (SET trong LAN)
alert http $HOME_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"PHISH DETECT Social-Engineer Toolkit - POST credentials in body to local IP";
    flow:to_server,established;
    http_client_body;
    pcre:"/(?:^|&)(?:login|username)=[^&]{1,128}&(?:password|pass)=[^&]{1,128}/i";
    sid:1009301; rev:1; classtype:attempted-admin;
)
# 1009303 - (tuỳ chọn) Bắt mọi POST tới bất kỳ IP (dùng khi attacker có thể ở ngoài LAN)
alert http $HOME_NET any -> any $HTTP_PORTS (
    msg:"PHISH DETECT Social-Engineer Toolkit - POST with credentials in body (any dest)";
    flow:to_server,established;
    http_client_body;
    pcre:"/(?:^|&)(?:login|username)=[^&]{1,128}&(?:password|pass)=[^&]{1,128}/i";
    sid:1009303; rev:1; classtype:attempted-admin;
)


###############################################
############################################################################
# SLOWLORIS - Lab detection (low thresholds, PSH-only to avoid RST noise)
############################################################################

############################################################################
# SLOWLORIS - LAB (rất nhạy, chỉ dùng test)
# Yêu cầu: HOME_NET có dải của server, HTTP_PORTS có {80,8081,443,...}
############################################################################

# D0 - DEBUG: bắt mọi gói client->HTTP có payload nhỏ (để xác nhận sensor thấy gói)
#alert tcp any any -> $HOME_NET $HTTP_PORTS (
#    msg:"DEBUG tiny client packet to HTTP (lab)";
#    flow:to_server;
#    dsize:<120;                     # chỉ 1 dsize / rule
#    sid:9911999; rev:2; classtype:unknown;
#)
alert tcp any any -> $HOME_NET [80,8081,443] (
    msg:"SLOWHTTP Slowloris";
    flow:to_server;
    flags:!R;               # bỏ qua RST
    dsize:<150;
    detection_filter:track by_src, count 3, seconds 15;
    sid:9911201; rev:1; classtype:attempted-dos;
)


# L1 - Slowloris: nhiều gói nhỏ drip header (không ràng established, KHÔNG lọc theo PSH)
#   (Một số TCP stack không set PSH đều đặn, nên bỏ lọc flags để khỏi miss)
#alert tcp any any -> $HOME_NET $HTTP_PORTS (
#    msg:"SLOWHTTP/L1 - many tiny client header fragments (lab)";
#    flow:to_server;
#    dsize:<100;
#    detection_filter:track by_src, count 5, seconds 30;
#    sid:9911001; rev:3; classtype:attempted-dos;
#)

# L2 - SYN nhiều tới HTTP (mở nhiều socket chờ drip)
alert tcp any any -> $HOME_NET $HTTP_PORTS (
    msg:"SLOWHTTP/L2 - many SYNs to HTTP (by_src, lab)";
    flags:S;
    detection_filter:track by_src, count 20, seconds 60;
    sid:9911002; rev:2; classtype:attempted-dos;
)

# L3 - Tổng hợp theo đích (nếu phân tán nhiều nguồn)
alert tcp any any -> $HOME_NET $HTTP_PORTS (
    msg:"SLOWHTTP/L3 - many tiny client packets to same HTTP dst (by_dst, lab)";
    flow:to_server;
    dsize:<100;
    detection_filter:track by_dst, count 100, seconds 60;
    sid:9911003; rev:3; classtype:attempted-dos;
)

