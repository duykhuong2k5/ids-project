#alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"WEB RCE - suspicious shell operator or more in URI"; flow:to_server,established; http_uri; pcre:"/(\|\||&&|;|`[^`]*`|\$\([^\)]+\)|\bmore\s+(?:\/[^\s]+|[A-Za-z]:\\[^\s]+))/i"; sid:1005001; rev:3; classtype:web-application-attack;)
#alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"WEB RCE - suspicious shell operator or more in URI"; flow:to_server,established; http_uri; pcre:"/(\|\||&&|;|`[^`]*`|\$\([^\)]+\)|\bmore\s+(?:\/[^\s]+|[A-Za-z]:\\[^\s]+))/i"; sid:1005001; rev:3; classtype:web-application-attack;)
#alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"WEB RCE - suspicious shell operator or more in URI"; flow:to_server,established; http_uri; pcre:"/(\|\||&&|;|`[^`]*`|\$\([^\)]+\)|\bmore\s+(?:\/[^\s]+|[A-Za-z]:\\[^\s]+))/i"; sid:1005001; rev:3; classtype:web-application-attack;)
# 1) || then more /path in request body (Linux or Windows path)
#alert http any any -> any 8081 (msg:"TEST RCE DVWA (encoded patterns in POST body)"; http_client_body; regex:"(?i)(\%7c\%7c\+more\+|\%26\%26\+cmd\+\%2fc|\%3eC\%3a\%5cxampp\%5ctmp\%5c)"; sid:1007202; rev:1; classtype:web-application-attack;)
# 1) Bắt dạng URL-encoded (theo tcpdump: %7C%7C, %26%26, %2Fc, C%3A%5C...)

#alert http any any -> any 8081 (msg:"WEB RCE DVWA - encoded patterns in POST body"; http_client_body; pcre:"/(%7C%7C\+more\+|%26%26\+cmd\+%2Fc|%3EC%3A%5Cxampp%5Ctmp%5C)/i"; sid:1100001; rev:1; classtype:web-application-attack;)
alert tcp any any -> any 8081 (msg:"WEB RCE DVWA - encoded or plain in TCP payload"; flow:to_server,established; pcre:"/(%7C%7C\+more\+|%26%26\+cmd\+%2Fc|%3EC%3A%5Cxampp%5Ctmp%5C|\|\|\s*more\s+|&&\s*cmd\s+\/c|>C:\\\\xampp\\\\tmp\\\\)/i"; sid:1300001; rev:1; classtype:web-application-attack;)



# Detect JSON POSTs containing "system_info"
# ----------------------------
# Match JSON key "system_info" anywhere in payload (no http_* dependence)
alert tcp any any -> 192.168.8.131 9999 (
    msg:"MALWARE-EXFIL: JSON POST contains \"system_info\" to C2:9999";
    flow:established,to_server;
    pcre:"/system_info/i";
    classtype:trojan-activity;
    sid:3002001;
    rev:1;
)

# Match key "passwords" (array/object)
alert tcp any any -> 192.168.8.131 9999 (
    msg:"MALWARE-EXFIL: POST contains \"passwords\" array/object to C2:9999";
    flow:established,to_server;
    pcre:"/\"passwords\"/i";
    classtype:trojan-activity;
    sid:3002002;
    rev:1;
)

# Match GET /checkin (simple line match)
alert tcp any any -> 192.168.8.131 9999 (
    msg:"MALWARE-CHECKIN: HTTP GET /checkin to C2:9999";
    flow:established,to_server;
    pcre:"/GET\s+\/checkin/i";
    classtype:trojan-activity;
    sid:3002006;
    rev:1;
)



# Optional: Block all traffic to C2 IP (use ONLY in IPS mode if you want active blocking)
#drop ip any any -> 192.168.8.131 any (
#    msg:"BLOCK-MALICIOUS: DROP all traffic to known C2 192.168.8.131 (IPS mode)";
#    classtype:trojan-activity;
#    sid:2000007;
#    rev:1;
#)

alert tcp 192.168.8.131 8000 -> any any (
  msg:"KHUONG-INVOICE: JPEG response contains malware marker '===KHUONG_MALWARE_START==='";
  flow:established,to_client;
  content:"image/jpeg"; http_header;
  file_data;
  content:"===KHUONG_MALWARE_START===";
  metadata:service http;
  classtype:trojan-activity;
  sid:3120002;
  rev:1;
)
alert tcp 192.168.8.131 8000 -> any any (
  msg:"KHUONG-INVOICE: Data appended after JPEG EOI (FFD9) containing malware marker";
  flow:established,to_client;
  content:"image/jpeg"; http_header;
  file_data;
  pcre:"/\xFF\xD9.{0,512}===KHUONG_MALWARE_START===/s";
  metadata:service http;
  classtype:trojan-activity;
  sid:3120003;
  rev:1;
)
